# Data (heavy; tracked via DVC, not git)
data/raw/
data/processed/
data/external/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Supersite raw downloads (heavy; track README + site_config only)
data/supersite_*/raw/
data/supersite_*/processed/

# Outputs (generated; reproducible from pipeline)
outputs/
!outputs/.gitkeep

# OS / editor
.DS_Store
